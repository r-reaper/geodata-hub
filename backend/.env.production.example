# ── Thai GeoData Hub — Production Environment Variables ──
# Copy this to .env on Railway (via Environment tab)

# ── Database (Railway PostgreSQL plugin provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Cloudflare R2 Storage
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY=<your-r2-access-key>
S3_SECRET_KEY=<your-r2-secret-key>
S3_REGION=auto
S3_BUCKET_NAME=thai-geodata-hub

# ── Stripe (use live keys in production)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── CORS (set to your Vercel frontend URL)
# Example: https://thai-geodata-hub.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── App
APP_ENV=production
DEBUG=false
