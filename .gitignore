# Secrets & user state — never commit
backend/.env
frontend/.env.local
backend/credits.json
backend/history.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Node
frontend/node_modules/
frontend/.next/

# Data (large GeoJSON files — store in R2, not git)
data/*.geojson
data/*.tif
data/*.zip
data/.*_state.json

# Claude / local IDE state — never commit (exposes local paths + username)
.claude/
.vscode/
.idea/
*.code-workspace

# Local dev scripts & throwaway test artifacts — keep out of public repo
debug_clip.py
clip_test_extract/
test_aoi*.json
test_overpass.py
clip_test/
clip_result/

# TypeScript build artifacts
frontend/tsconfig.tsbuildinfo
frontend/.next/

# Build artifacts
*.zip
clip_result.zip
clip_test.zip
dist/
build/

# OS
.DS_Store
Thumbs.db
